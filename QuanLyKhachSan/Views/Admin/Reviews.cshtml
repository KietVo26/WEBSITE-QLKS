@model IEnumerable<QuanLyKhachSan.Models.DanhGia>
@{
    ViewData["Title"] = "Quản lý Đánh giá";
    Layout = "_AdminLayout";
    var search = ViewBag.Search as string ?? "";
    var stars = ViewBag.Stars as int?;
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "nhanvien";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h2 class="fw-bold font-serif m-0" style="font-family: 'Cormorant Garamond', serif;"><i class="fa-solid fa-star text-gold me-2" style="color: #C8A96E;"></i> Quản lý Đánh giá & Nhận xét</h2>
</div>

<!-- Bộ lọc tìm kiếm -->
<div class="card border-0 shadow-sm rounded-4 p-4 mb-4" style="background-color: #FAF8F3;">
    <form method="get" asp-controller="Admin" asp-action="Reviews" class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label fw-bold small text-muted text-uppercase">Tìm kiếm</label>
            <input type="text" name="search" class="form-control rounded-3" placeholder="Tên khách, SĐT, loại phòng, nhận xét..." value="@search" />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold small text-muted text-uppercase">Số sao</label>
            <select name="stars" class="form-select rounded-3">
                <!option value="" @(stars == null ? "selected" : "")>Tất cả số sao</!option>
                <!option value="5" @(stars == 5 ? "selected" : "")>5 Sao ⭐⭐⭐⭐⭐</!option>
                <!option value="4" @(stars == 4 ? "selected" : "")>4 Sao ⭐⭐⭐⭐</!option>
                <!option value="3" @(stars == 3 ? "selected" : "")>3 Sao ⭐⭐⭐</!option>
                <!option value="2" @(stars == 2 ? "selected" : "")>2 Sao ⭐⭐</!option>
                <!option value="1" @(stars == 1 ? "selected" : "")>1 Sao ⭐</!option>
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-dark rounded-3 flex-grow-1" style="background-color: #0D0D0F; color: #C8A96E; border-color: #0D0D0F;">
                <i class="fa-solid fa-magnifying-glass me-2"></i>Tìm kiếm
            </button>
            <a asp-controller="Admin" asp-action="Reviews" class="btn btn-outline-secondary rounded-3">
                <i class="fa-solid fa-rotate-left"></i>
            </a>
        </div>
    </form>
</div>

<!-- Danh sách đánh giá -->
@if (!Model.Any())
{
    <div class="text-center py-5 bg-white rounded-4 shadow-sm">
        <i class="fa-solid fa-comment-slash fs-1 text-muted mb-3"></i>
        <h5 class="fw-bold text-muted">Không tìm thấy đánh giá nào!</h5>
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark" style="background-color: #0D0D0F;">
                    <tr>
                        <th class="ps-4">Mã DG</th>
                        <th>Khách Hàng</th>
                        <th>Loại Phòng</th>
                        <th>Đánh Giá</th>
                        <th style="max-width: 300px;">Nhận Xét / Góp Ý</th>
                        <th>Ngày Gửi</th>
                        @if (role == "admin")
                        {
                            <th class="text-end pe-4">Thao tác</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dg in Model)
                    {
                        <tr>
                            <td class="fw-bold ps-4 text-primary">#@dg.MaDG</td>
                            <td>
                                <div class="fw-bold">@dg.KhachHang.HoTen</div>
                                <div class="small text-muted">@dg.KhachHang.SDT</div>
                            </td>
                            <td>@dg.LoaiPhong.TenLoai</td>
                            <td>
                                <div class="text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fa-@(i <= dg.SoSao ? "solid" : "regular") fa-star" style="color: #FFC107;"></i>
                                    }
                                </div>
                            </td>
                            <td style="max-width: 300px; white-space: normal; word-wrap: break-word;">
                                @if (string.IsNullOrEmpty(dg.NhanXet))
                                {
                                    <span class="text-muted small italic">Không có nhận xét viết tay</span>
                                }
                                else
                                {
                                    @dg.NhanXet
                                }
                            </td>
                            <td>@dg.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")</td>
                            @if (role == "admin")
                            {
                                <td class="text-end pe-4">
                                    <a asp-controller="Admin" asp-action="DeleteReview" asp-route-id="@dg.MaDG" 
                                       class="btn btn-outline-danger btn-sm rounded-3" 
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa đánh giá này không?');">
                                        <i class="fa-solid fa-trash"></i> Xóa
                                    </a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
