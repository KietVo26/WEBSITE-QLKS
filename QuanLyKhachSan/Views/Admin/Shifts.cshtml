@{
    ViewData["Title"] = "Quản lý Ca làm việc & Chấm công";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var shifts = ViewBag.Shifts as IEnumerable<QuanLyKhachSan.Models.CaLamViec> ?? new List<QuanLyKhachSan.Models.CaLamViec>();
    var schedules = ViewBag.Schedules as IEnumerable<QuanLyKhachSan.Models.LichLamViec> ?? new List<QuanLyKhachSan.Models.LichLamViec>();
    var attendance = ViewBag.Attendance as IEnumerable<QuanLyKhachSan.Models.ChamCong> ?? new List<QuanLyKhachSan.Models.ChamCong>();
    var employees = ViewBag.Employees as IEnumerable<QuanLyKhachSan.Models.NhanVien> ?? new List<QuanLyKhachSan.Models.NhanVien>();
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold m-0"><i class="fa-solid fa-clock text-primary me-2"></i> Ca Làm Việc & Điểm Danh Chấm Công</h2>
        <p class="text-muted">Lịch phân ca tuần này của nhân viên và trạng thái điểm danh ngày hôm nay.</p>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- SHIFT CATALOG -->
    <div class="col-md-7">
        <div class="card p-4 border-0 shadow-sm h-100">
            <h4 class="fw-bold mb-3 text-dark"><i class="fa-solid fa-business-time text-primary me-2"></i>Khung giờ Ca làm việc cố định</h4>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Tên Ca</th>
                            <th>Giờ Bắt Đầu</th>
                            <th>Giờ Kết Thúc</th>
                            <th>Mô tả công việc</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in shifts)
                        {
                            <tr>
                                <td class="fw-bold">@c.TenCa</td>
                                <td class="text-success fw-bold">@c.GioBatDau.ToString(@"hh\:mm")</td>
                                <td class="text-danger fw-bold">@c.GioKetThuc.ToString(@"hh\:mm")</td>
                                <td class="text-muted small">@c.MoTa</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- SCHEDULE ASSIGNMENT FORM -->
    <div class="col-md-5">
        <div class="card p-4 border-0 shadow-sm rounded-4" style="background-color: #FAF8F3;">
            <h4 class="fw-bold mb-3 text-dark"><i class="fa-solid fa-calendar-plus text-success me-1"></i>Phân ca cho nhân viên</h4>
            <form asp-controller="Admin" asp-action="AddSchedule" method="post">
                @Html.AntiForgeryToken()
                
                <div class="mb-3">
                    <label class="form-label small fw-bold text-secondary">Nhân Viên (*)</label>
                    <select name="employeeId" class="form-select border-0 bg-white" required>
                        <option value="">-- Chọn Nhân Viên --</option>
                        @foreach (var emp in employees)
                        {
                            <option value="@emp.MaNV">@emp.TaiKhoan.HoTen (@emp.ChucVu)</option>
                        }
                    </select>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label small fw-bold text-secondary">Chọn Ca (*)</label>
                        <select name="shiftId" class="form-select border-0 bg-white" required>
                            <option value="">-- Chọn Ca --</option>
                            @foreach (var c in shifts)
                            {
                                <option value="@c.MaCa">@c.TenCa</option>
                            }
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label small fw-bold text-secondary">Ngày Làm Việc (*)</label>
                        <input type="date" name="workDate" class="form-control border-0 bg-white" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-secondary">Ghi chú</label>
                    <input type="text" name="note" class="form-control border-0 bg-white" placeholder="VD: Trực thay lễ tân..." />
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2"><i class="fa-solid fa-save me-1"></i>Lưu Lịch Phân Ca</button>
            </form>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- WEEKLY SCHEDULE TABLE -->
    <div class="col-md-6">
        <div class="card p-4 border-0 shadow-sm h-100">
            <h4 class="fw-bold mb-3 text-dark"><i class="fa-solid fa-calendar-days text-primary me-2"></i>Lịch phân ca trong tuần</h4>
            @if (!schedules.Any())
            {
                <p class="text-muted small m-0">Chưa có lịch phân ca làm việc cho tuần này.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle table-sm small">
                        <thead>
                            <tr>
                                <th>Ngày</th>
                                <th>Nhân Viên</th>
                                <th>Ca Làm Việc</th>
                                <th>Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sc in schedules)
                            {
                                <tr>
                                    <td class="fw-bold text-dark">@sc.NgayLam.ToString("dd/MM")</td>
                                    <td>@sc.NhanVien.TaiKhoan.HoTen</td>
                                    <td>
                                        <span class="badge bg-secondary">@sc.CaLamViec.TenCa</span>
                                    </td>
                                    <td class="text-muted small">@sc.GhiChu</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- ATTENDANCE FOR TODAY -->
    <div class="col-md-6">
        <div class="card p-4 border-0 shadow-sm h-100">
            <h4 class="fw-bold mb-3 text-dark"><i class="fa-solid fa-user-check text-primary me-2"></i>Trạng thái chấm công hôm nay</h4>
            @if (!attendance.Any())
            {
                <p class="text-muted small m-0">Hôm nay chưa có dữ liệu điểm danh.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle table-sm small">
                        <thead>
                            <tr>
                                <th>Nhân Viên</th>
                                <th>Giờ Vào</th>
                                <th>Giờ Ra</th>
                                <th>Trạng Thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cc in attendance)
                            {
                                var statusBadge = "bg-success";
                                if (cc.TrangThai == "tre") statusBadge = "bg-warning text-dark";
                                else if (cc.TrangThai == "vang_mat") statusBadge = "bg-danger";

                                <tr>
                                    <td class="fw-bold">@cc.NhanVien.TaiKhoan.HoTen</td>
                                    <td>@(cc.GioVao.HasValue ? cc.GioVao.Value.ToString(@"hh\:mm") : "—")</td>
                                    <td>@(cc.GioRa.HasValue ? cc.GioRa.Value.ToString(@"hh\:mm") : "—")</td>
                                    <td>
                                        <span class="badge @statusBadge">
                                            @cc.TrangThai
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
