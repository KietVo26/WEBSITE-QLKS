@using System.Security.Claims
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject QuanLyKhachSan.Data.ApplicationDbContext DbContext

@{
    var username = User.Identity?.Name ?? "Admin";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "nhanvien";
    
    // Đếm số đơn đặt phòng chờ duyệt để hiển thị chuông thông báo
    int pendingCount = 0;
    try
    {
        pendingCount = DbContext.DatPhongs.Count(dp => dp.TrangThai == "Chờ xác nhận");
    }
    catch { }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — K-Hotel Admin</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/assets/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/admin-luxestay.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-logo">
        <div class="logo-text">✦ K-Hotel</div>
        <div class="logo-sub">Hotel Management</div>
      </div>
      <nav class="sidebar-nav">
        <div class="nav-section-label">Tổng quan</div>
        <a asp-controller="Admin" asp-action="RoomMap" class="nav-item">
          <span class="icon">📊</span> Sơ đồ phòng (Room Map)
        </a>

        <div class="nav-section-label">Quản lý</div>
        <a asp-controller="Admin" asp-action="RoomMap" class="nav-item">
          <span class="icon">🏨</span> Sơ đồ phòng
        </a>
        <a asp-controller="Admin" asp-action="Customers" class="nav-item">
          <span class="icon">👥</span> Khách hàng
        </a>
        <a asp-controller="Admin" asp-action="Shifts" class="nav-item">
          <span class="icon">🛎️</span> Phân ca & Chấm công
        </a>
        <a asp-controller="Admin" asp-action="Vouchers" class="nav-item">
          <span class="icon">🎟️</span> Quản lý Voucher
        </a>
        @if (role == "admin")
        {
            <a asp-controller="Admin" asp-action="Employees" class="nav-item">
              <span class="icon">👔</span> Quản lý Nhân viên
            </a>
        }

        <div class="nav-section-label">Hệ thống</div>
        <a asp-controller="Home" asp-action="Index" class="nav-item" style="opacity: 0.8;">
          <span class="icon">🌐</span> Cổng Khách Hàng
        </a>
      </nav>
      <div class="sidebar-footer">
        <div class="user-card">
          <div class="avatar">@username.Substring(0, 1).ToUpper()</div>
          <div class="user-info">
            <div class="name">@username</div>
            <div class="role">@(role == "admin" ? "Quản trị viên" : "Nhân viên")</div>
          </div>
        </div>
      </div>
    </aside>

    <!-- MAIN -->
    <div class="main">
      <header class="topbar">
        <button id="sidebarToggle" class="topbar-btn btn-ghost d-lg-none" style="padding: 0; width: 40px; height: 40px; font-size: 20px;">
          <i class="fa-solid fa-bars"></i>
        </button>
        <div class="topbar-title">K-Hotel <span>✦</span> Admin</div>
        
        <a asp-controller="Admin" asp-action="RoomMap" class="notif-btn" style="text-decoration: none; position: relative;" title="@(pendingCount > 0 ? $"Có {pendingCount} đơn chờ duyệt" : "Không có thông báo mới")">
          🔔
          @if (pendingCount > 0)
          {
            <div class="notif-dot" style="display: flex; align-items: center; justify-content: center; width: 16px; height: 16px; top: -2px; right: -2px; font-size: 9px; font-weight: bold; color: white; text-decoration: none;">@pendingCount</div>
          }
        </a>
        <a asp-controller="Account" asp-action="Logout" class="topbar-btn btn-ghost" style="text-decoration:none; color:inherit;">Đăng xuất</a>
      </header>

      <div class="content p-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert" style="border-left: 5px solid #198754 !important;">
                <i class="fa-solid fa-circle-check me-2"></i> @Html.Raw(TempData["SuccessMessage"])
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert" style="border-left: 5px solid #dc3545 !important;">
                <i class="fa-solid fa-circle-exclamation me-2"></i> @Html.Raw(TempData["ErrorMessage"])
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
      </div>
    </div>

    <!-- Bootstrap 5 Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const toggle = document.getElementById('sidebarToggle');
            const sidebar = document.querySelector('.sidebar');
            
            if (toggle && sidebar) {
                toggle.addEventListener('click', function() {
                    sidebar.classList.toggle('sidebar-open');
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
