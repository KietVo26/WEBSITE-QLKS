@model IEnumerable<QuanLyKhachSan.Models.LoaiPhong>
@{
    ViewData["Title"] = "K-Hotel — Nghỉ Dưỡng Đẳng Cấp";
    var recommendations = ViewBag.Recommendations as IEnumerable<QuanLyKhachSan.Controllers.PhongViewModel> ?? new List<QuanLyKhachSan.Controllers.PhongViewModel>();
    var statRooms = ViewBag.StatRooms ?? 0;
    var statRating = ViewBag.StatRating ?? 4.8;
}

<!-- HERO COVER -->
<div class="position-relative overflow-hidden bg-dark text-light py-5" style="background: linear-gradient(rgba(13,13,15,0.65), rgba(13,13,15,0.85)), url('https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?q=80&w=1920') no-repeat center center; background-size: cover; min-height: 80vh; display: flex; align-items: center;">
    <div class="container text-center py-5">
        <h5 class="text-uppercase tracking-widest text-gold mb-3" style="color: #C8A96E; letter-spacing: 3px; font-family: 'DM Sans', sans-serif;">✦✦✦ KHÁCH SẠN HẠNG SANG ✦✦✦</h5>
        <h1 class="display-3 fw-bold font-serif mb-4" style="font-family: 'Cormorant Garamond', serif;">Nghỉ Dưỡng Đẳng Cấp Obsidian & Gold</h1>
        <p class="lead text-white-50 mb-5 mx-auto max-w-2xl" style="max-width: 600px;">Trải nghiệm sự xa hoa kết hợp hài hòa nét cổ điển tinh tế. Hãy tìm kiếm phòng trống lý tưởng dành riêng cho bạn ngay hôm nay.</p>
        
        <!-- SEARCH BAR -->
        <div class="bg-white text-dark rounded-4 shadow-lg p-3 mx-auto" style="max-width: 950px;">
            <form asp-controller="Home" asp-action="Search" method="get">
                <div class="row g-2 align-items-center">
                    <div class="col-md-3">
                        <div class="text-start px-2">
                            <label class="small text-muted fw-bold text-uppercase"><i class="fa-solid fa-map-pin text-primary me-1"></i> Khu vực</label>
                            <select name="khuvuc" class="form-select border-0 shadow-none bg-transparent">
                                <option value="">Tất cả khu vực</option>
                                <option value="Hồ Chí Minh">Hồ Chí Minh</option>
                                <option value="Hà Nội">Hà Nội</option>
                                <option value="Đà Nẵng">Đà Nẵng</option>
                                <option value="Phan Thiết">Phan Thiết</option>
                                <option value="Tây Ninh">Tây Ninh</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-start px-2">
                            <label class="small text-muted fw-bold text-uppercase"><i class="fa-solid fa-calendar me-1"></i> Ngày nhận phòng</label>
                            <input type="datetime-local" name="checkin" class="form-control border-0 shadow-none bg-transparent" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-start px-2">
                            <label class="small text-muted fw-bold text-uppercase"><i class="fa-solid fa-calendar me-1"></i> Ngày trả phòng</label>
                            <input type="datetime-local" name="checkout" class="form-control border-0 shadow-none bg-transparent" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-ddTHH:mm")" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-start px-2">
                            <label class="small text-muted fw-bold text-uppercase"><i class="fa-solid fa-users me-1"></i> Số khách</label>
                            <select name="guest" class="form-select border-0 shadow-none bg-transparent">
                                <option value="1">1 Khách</option>
                                <option value="2" selected>2 Khách</option>
                                <option value="4">4 Khách</option>
                                <option value="6">Gia đình (6+)</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-dark w-100 rounded-3 py-3" style="background-color: #0D0D0F; border-color: #0D0D0F; color: #C8A96E;"><i class="fa-solid fa-search"></i> Tìm phòng</button>
                    </div>
                </div>
            </form>
        </div>

        <div class="d-flex justify-content-center gap-4 mt-5">
            <div class="text-white-50"><span class="fw-bold text-white fs-4">@statRooms</span> Phòng trống khả dụng</div>
            <div class="text-white-50"><span class="fw-bold text-white fs-4">@statRating ★</span> Điểm đánh giá dịch vụ</div>
        </div>
    </div>
</div>

<!-- RECOMMENDED ROOMS SECTION -->
<div class="container py-5 my-4">
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-3">
        <div>
            <h5 class="text-gold text-uppercase" style="color: #C8A96E; font-family: 'DM Sans', sans-serif;">GỢI Ý CỦA AI</h5>
            <h2 class="fw-bold font-serif m-0" style="font-family: 'Cormorant Garamond', serif;">Phòng Trống Gợi Ý Cho Bạn</h2>
        </div>
        <span class="badge bg-dark p-2 text-gold" style="color: #C8A96E;"><i class="fa-solid fa-wand-magic-sparkles"></i> Hệ thống đề xuất cá nhân hóa</span>
    </div>
    
    <div class="row g-4">
        @foreach (var rec in recommendations)
        {
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative">
                    <img src="@(rec.Room.LoaiPhong.HinhAnh.StartsWith("http") ? rec.Room.LoaiPhong.HinhAnh : "/assets/img/" + rec.Room.LoaiPhong.HinhAnh)" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@rec.Room.LoaiPhong.TenLoai" />
                    
                    @if (rec.Score > 0)
                    {
                        <span class="badge bg-success position-absolute top-0 start-0 m-3 px-3 py-2" style="font-size:0.75rem;"><i class="fa-solid fa-heart me-1"></i> Ưu thích (@(Math.Round(rec.Score))đ)</span>
                    }
                    else
                    {
                        <span class="badge bg-dark text-gold position-absolute top-0 start-0 m-3 px-3 py-2" style="font-size:0.75rem; color: #C8A96E;"><i class="fa-solid fa-crown me-1"></i> Phòng VIP</span>
                    }

                    <div class="card-body p-3">
                        <small class="text-primary fw-bold text-uppercase"><i class="fa-solid fa-location-dot"></i> @rec.Room.LoaiPhong.KhuVuc</small>
                        <h5 class="card-title fw-bold my-2">@rec.Room.LoaiPhong.TenLoai - @rec.Room.MaPhong</h5>
                        <p class="card-text text-muted small text-truncate">@rec.Room.LoaiPhong.TienNghi</p>
                        
                        <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                            <div>
                                <span class="fw-bold text-danger">@rec.Room.LoaiPhong.GiaPhong.ToString("N0") ₫</span>
                                <small class="text-muted">/ đêm</small>
                            </div>
                            <a asp-controller="Home" asp-action="Detail" asp-route-id="@rec.Room.MaLoai" class="btn btn-outline-dark btn-sm rounded-2">Chi tiết</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- CATEGORY CATALOG BY REGIONS -->
<div class="container py-5 my-4">
    <div class="text-center mb-5">
        <h5 class="text-gold text-uppercase" style="color: #C8A96E;">PHÂN KHU KHÁCH SẠN</h5>
        <h2 class="fw-bold font-serif display-4" style="font-family: 'Cormorant Garamond', serif;">Hệ Thống Phòng Khách Sạn</h2>
    </div>

    @{
        var regions = Model.GroupBy(x => x.KhuVuc).ToList();
        var regionIcons = new Dictionary<string, string>
        {
            { "Phan Thiết", "fa-umbrella-beach" },
            { "Hà Nội", "fa-landmark" },
            { "Hồ Chí Minh", "fa-city" },
            { "Tây Ninh", "fa-mountain-sun" },
            { "Đà Nẵng", "fa-water" }
        };
    }

    @foreach (var region in regions)
    {
        var icon = regionIcons.ContainsKey(region.Key) ? regionIcons[region.Key] : "fa-hotel";
        
        <div class="mb-5">
            <div class="d-flex align-items-center gap-2 mb-4 pb-2 border-bottom">
                <i class="fa-solid @icon fs-3 text-gold" style="color:#C8A96E;"></i>
                <h3 class="fw-bold font-serif m-0" style="font-family: 'Cormorant Garamond', serif;">Khu vực @region.Key</h3>
                <span class="badge bg-light text-dark border ms-2">@region.Count() hạng phòng</span>
            </div>
            
            <div class="row g-4">
                @foreach (var lp in region)
                {
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                            <div class="position-relative">
                                <img src="@(lp.HinhAnh.StartsWith("http") ? lp.HinhAnh : "/assets/img/" + lp.HinhAnh)" class="card-img-top" style="height: 240px; object-fit: cover;" alt="@lp.TenLoai" />
                                <span class="badge bg-dark text-gold position-absolute bottom-0 end-0 m-3 px-3 py-2" style="font-size:0.9rem; color: #C8A96E;">@lp.GiaPhong.ToString("N0") ₫ / đêm</span>
                            </div>
                            <div class="card-body p-4">
                                <h4 class="fw-bold font-serif mb-2" style="font-family: 'Cormorant Garamond', serif;">@lp.TenLoai</h4>
                                <div class="d-flex gap-3 text-muted small mb-3">
                                    <span><i class="fa-solid fa-users"></i> Tối đa: @lp.SoNguoiToiDa khách</span>
                                    <span><i class="fa-solid fa-hotel"></i> Khu: @lp.KhuVuc</span>
                                </div>
                                <p class="card-text text-muted small" style="min-height: 40px;"><strong>Tiện ích:</strong> @lp.TienNghi</p>
                                <div class="d-grid mt-4">
                                    <a asp-controller="Home" asp-action="Detail" asp-route-id="@lp.MaLoai" class="btn btn-dark rounded-3" style="background-color: #0D0D0F; border-color: #0D0D0F; color: #C8A96E;">Đặt phòng & Đánh giá</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
