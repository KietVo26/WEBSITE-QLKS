@model QuanLyKhachSan.Models.LoaiPhong
@{
    ViewData["Title"] = Model.TenLoai;
    var reviews = ViewBag.Reviews as IEnumerable<QuanLyKhachSan.Models.DanhGia> ?? new List<QuanLyKhachSan.Models.DanhGia>();
    var avgStars = ViewBag.AverageStars ?? 5.0;
    var vacantRooms = ViewBag.VacantRooms as IEnumerable<QuanLyKhachSan.Models.Phong> ?? new List<QuanLyKhachSan.Models.Phong>();
}

<div class="container py-5">
    <div class="row g-5">
        <!-- LEFT: ROOM DETAILS & REVIEWS -->
        <div class="col-md-7">
            <!-- Room Image & Info -->
            <div class="mb-5">
                <img src="@(Model.HinhAnh.StartsWith("http") ? Model.HinhAnh : "/assets/img/" + Model.HinhAnh)" class="img-fluid rounded-4 shadow-sm w-100 mb-4" style="height: 450px; object-fit: cover;" alt="@Model.TenLoai" />
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="badge bg-dark text-gold px-3 py-2 fs-6" style="color: #C8A96E;"><i class="fa-solid fa-map-pin"></i> Khu vực: @Model.KhuVuc</span>
                    <h3 class="text-danger fw-bold m-0">@Model.GiaPhong.ToString("N0") ₫ <span class="text-muted fs-6">/ đêm</span></h3>
                </div>
                <h1 class="fw-bold font-serif display-5 mb-3" style="font-family: 'Cormorant Garamond', serif;">@Model.TenLoai</h1>
                
                <div class="d-flex gap-4 text-muted border-top border-bottom py-3 mb-4">
                    <span><i class="fa-solid fa-users me-2"></i>Tối đa: <strong>@Model.SoNguoiToiDa</strong> người</span>
                    <span><i class="fa-solid fa-hotel me-2"></i>Số phòng trống: <strong>@vacantRooms.Count()</strong></span>
                    <span><i class="fa-solid fa-star me-2 text-warning"></i>Đánh giá: <strong>@avgStars / 5.0</strong></span>
                </div>

                <h4 class="fw-bold mb-3">Tiện ích trong phòng</h4>
                <p class="text-muted leading-relaxed">@Model.TienNghi</p>
            </div>

            <!-- Reviews Section -->
            <div class="reviews-box border-top pt-5">
                <h3 class="fw-bold font-serif mb-4" style="font-family: 'Cormorant Garamond', serif;">Đánh giá từ khách hàng (@reviews.Count())</h3>
                
                @if (!reviews.Any())
                {
                    <p class="text-muted">Chưa có đánh giá nào cho hạng phòng này. Hãy là người đầu tiên trải nghiệm và chia sẻ cảm nhận!</p>
                }
                else
                {
                    <div class="d-flex align-items-center gap-3 mb-4 p-3 bg-light rounded-4">
                        <div class="text-center">
                            <h1 class="display-3 fw-bold m-0">@avgStars</h1>
                            <small class="text-muted">trên 5 sao</small>
                        </div>
                        <div class="vr"></div>
                        <div>
                            <div class="text-warning fs-4">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Round(Convert.ToDouble(avgStars)))
                                    {
                                        <span>★</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">★</span>
                                    }
                                }
                            </div>
                            <small class="text-muted d-block mt-1">Đánh giá thực tế từ khách lưu trú</small>
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-4">
                        @foreach (var r in reviews)
                        {
                            <div class="p-4 border rounded-4 bg-white shadow-sm">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <strong class="d-block">@r.KhachHang.HoTen</strong>
                                        <small class="text-muted">Ngày: @r.NgayDanhGia.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <div class="text-warning">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            @(i <= r.SoSao ? "★" : "☆")
                                        }
                                    </div>
                                </div>
                                <p class="text-muted m-0 italic">"@r.NhanXet"</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- RIGHT: BOOKING PANEL -->
        <div class="col-md-5">
            <div class="card p-4 border-0 shadow-lg rounded-4 sticky-top" style="top: 100px; background-color: #FAF8F3;">
                <h3 class="fw-bold font-serif mb-4" style="font-family: 'Cormorant Garamond', serif;"><i class="fa-solid fa-calendar-check text-gold me-2" style="color: #C8A96E;"></i> Đặt phòng trực tuyến</h3>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("khach"))
                    {
                        @if (!vacantRooms.Any())
                        {
                            <div class="alert alert-warning border-0 text-center py-4 rounded-3">
                                <i class="fa-solid fa-ban fs-3 mb-2 d-block"></i>
                                Hạng phòng này hiện tại đã hết phòng trống khả dụng! Vui lòng chọn hạng phòng khác.
                            </div>
                        }
                        else
                        {
                            <form asp-controller="Booking" asp-action="BookOnline" method="post">
                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-muted">Chọn phòng cụ thể (*)</label>
                                    <select name="maphong" class="form-select rounded-3 border-0 bg-white shadow-sm" required>
                                        <option value="">-- Chọn phòng --</option>
                                        @foreach (var room in vacantRooms)
                                        {
                                            <option value="@room.MaPhong">Phòng @room.MaPhong</option>
                                        }
                                    </select>
                                </div>

                                <div class="row g-2 mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Ngày Check-in (*)</label>
                                        <input type="datetime-local" name="ngayvao" class="form-control rounded-3 border-0 bg-white shadow-sm" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Ngày Check-out (*)</label>
                                        <input type="datetime-local" name="ngayra" class="form-control rounded-3 border-0 bg-white shadow-sm" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-ddTHH:mm")" required />
                                    </div>
                                </div>

                                <div class="row g-2 mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Số khách ở (*)</label>
                                        <input type="number" name="so_nguoi" class="form-control rounded-3 border-0 bg-white shadow-sm" min="1" max="@Model.SoNguoiToiDa" value="1" required />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Mã Voucher (nếu có)</label>
                                        <input type="text" name="voucher_code" class="form-control rounded-3 border-0 bg-white shadow-sm" placeholder="VD: LUCK10" />
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-muted">Ghi chú đặc biệt</label>
                                    <textarea name="ghichu" class="form-control rounded-3 border-0 bg-white shadow-sm" rows="3" placeholder="Yêu cầu giường phụ, phòng tầng cao..."></textarea>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted">Phương thức thanh toán (*)</label>
                                    <div class="d-flex gap-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="payment" id="payCash" value="Tiền mặt" checked>
                                            <label class="form-check-label fw-medium" for="payCash">Tiền mặt tại quầy</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="radio" name="payment" id="payOnline" value="Online">
                                            <label class="form-check-label fw-medium text-success" for="payOnline"><i class="fa-solid fa-credit-card me-1"></i>Thanh toán Online</label>
                                        </div>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-dark w-100 py-3 rounded-3" style="background-color: #0D0D0F; color: #C8A96E; border-color: #0D0D0F; font-size: 1.1rem;">
                                    <i class="fa-solid fa-circle-check me-2"></i> Xác nhận đặt phòng ngay
                                </button>
                            </form>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info border-0 text-center py-4 rounded-3">
                            <i class="fa-solid fa-user-shield fs-3 mb-2 d-block"></i>
                            Tài khoản của bạn là nhân viên/quản trị viên. Vui lòng đặt phòng tại trang nghiệp vụ Sơ đồ phòng.
                            <div class="mt-3">
                                <a asp-controller="Admin" asp-action="RoomMap" class="btn btn-primary btn-sm rounded-3">Đến Sơ đồ phòng</a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fa-solid fa-lock fs-2 text-muted mb-3"></i>
                        <h5 class="fw-bold mb-3">Vui lòng đăng nhập</h5>
                        <p class="text-muted small mb-4">Bạn cần đăng nhập tài khoản Khách Hàng để đặt phòng trực tuyến và tích lũy điểm thưởng.</p>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-dark w-100 rounded-3 py-2" style="background-color: #0D0D0F; color: #C8A96E; border-color: #0D0D0F;">Đăng nhập để đặt phòng</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
