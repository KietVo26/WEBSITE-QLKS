@{
    ViewData["Title"] = "Xác Thực Mã OTP";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Xác minh OTP — K-Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #0C0C0E 0%, #1a2a3a 50%, #1e3a5f 100%);
            display: flex; align-items: center; justify-content: center;
            min-height: 100vh; font-family: system-ui, sans-serif;
            padding: 20px;
        }
        .otp-panel {
            background: white;
            border-radius: 24px;
            padding: 40px;
            width: 100%; max-width: 440px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }
        .logo-box {
            border: 2px solid #111; padding: 4px 12px;
            font-family: serif; font-size: 1.3rem; font-weight: bold;
            display: inline-block; letter-spacing: 1px;
            margin-bottom: 20px;
        }
        .otp-input {
            font-size: 2.2rem;
            letter-spacing: 8px;
            text-align: center;
            font-weight: bold;
            border: 2px solid #cbd5e1;
            border-radius: 12px;
            padding: 10px;
            outline: none;
            color: #1e3a5f;
        }
        .otp-input:focus {
            border-color: #2563eb;
        }
        .error-box {
            background: rgba(220,53,69,0.06);
            border-left: 4px solid #dc3545;
            color: #b91c1c;
            padding: 12px;
            border-radius: 8px;
            font-size: 0.9rem;
            text-align: left;
        }
    </style>
</head>
<body>
    <div class="otp-panel text-center">
        <div class="logo-box">K-HOTEL</div>
        <h3 class="fw-bold mb-2">Xác Thực Tài Khoản</h3>
        <p class="text-muted small px-3">Chúng tôi đã gửi mã xác thực gồm 6 chữ số đến email đăng ký của bạn. Vui lòng nhập mã để kích hoạt tài khoản.</p>

        @if (ViewBag.Error != null)
        {
            <div class="error-box my-3">
                <i class="fa-solid fa-triangle-exclamation me-1"></i> @Html.Raw(ViewBag.Error)
            </div>
        }

        <form asp-controller="Account" asp-action="VerifyOtp" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <input type="text" name="otp" class="form-control otp-input w-100 mx-auto" maxlength="6" placeholder="000000" required autofocus autocomplete="off" />
            </div>
            
            <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold text-uppercase" style="background: #1e3a5f; border: none;">Kích hoạt tài khoản</button>
        </form>

        <div class="mt-4 small text-muted">
            Không nhận được mã? <a asp-controller="Account" asp-action="Register" class="text-decoration-none fw-bold text-primary">Gửi lại OTP</a>
        </div>
    </div>
</body>
</html>
