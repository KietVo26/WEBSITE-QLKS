@{
    ViewData["Title"] = "Đăng Ký Tài Khoản";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký - K-Hotel</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #1e3a5f;
            --accent: #2563eb;
            --glass: rgba(255, 255, 255, 0.95);
        }
        body {
            background: linear-gradient(135deg, #0C0C0E 0%, #1a2a3a 50%, #1e3a5f 100%);
            background-attachment: fixed;
            display: flex; align-items: center; justify-content: center;
            min-height: 100vh; font-family: 'Segoe UI', system-ui, sans-serif;
            padding: 20px;
            color: #333;
        }
        .glass-panel {
            background: var(--glass);
            border-radius: 24px;
            padding: 40px;
            width: 100%; max-width: 480px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.2);
        }
        .logo-box {
            border: 2.5px solid #1a1a1a; padding: 4px 12px;
            font-family: serif; font-size: 1.4rem; font-weight: bold;
            display: inline-block; letter-spacing: 1px;
        }
        .input-group-text {
            background-color: transparent;
            border-right: none;
            color: #64748b;
        }
        .form-control {
            border-left: none;
        }
        .form-control:focus {
            box-shadow: none;
            border-color: #dee2e6;
        }
        .btn-register {
            background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
            border: none;
            padding: 12px;
            font-weight: bold;
            border-radius: 12px;
            color: white;
            transition: all 0.2s;
        }
        .btn-register:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(37,99,235,0.25);
        }
        .error-box {
            background: rgba(220,53,69,0.06);
            border-left: 4px solid #dc3545;
            color: #b91c1c;
            padding: 12px;
            border-radius: 8px;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="glass-panel">
        <div class="text-center mb-4">
            <div class="logo-box mb-2">K-HOTEL</div>
            <h3 class="fw-bold m-0 text-dark">Đăng Ký Thành Viên</h3>
            <p class="text-muted small mt-1">Đăng ký tài khoản để nhận ưu đãi VIP và lưu lịch sử đặt chỗ</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-box mb-4">
                <i class="fa-solid fa-circle-exclamation me-1"></i> @Html.Raw(ViewBag.Error)
            </div>
        }

        <form asp-controller="Account" asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            
            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary text-uppercase">Họ và tên (*)</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-user-tag"></i></span>
                    <input type="text" name="hoten" class="form-control rounded-end-3" placeholder="Nguyễn Văn A" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary text-uppercase">Tên đăng nhập (*)</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-user"></i></span>
                    <input type="text" name="username" class="form-control rounded-end-3" placeholder="TenDangNhap123" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-bold text-secondary text-uppercase">Mật khẩu (*)</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" name="password" class="form-control rounded-end-3" placeholder="Tối thiểu 6 ký tự" required />
                </div>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-6">
                    <label class="form-label small fw-bold text-secondary text-uppercase">Số điện thoại (*)</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-phone"></i></span>
                        <input type="text" name="sdt" class="form-control rounded-end-3" placeholder="0901234567" required />
                    </div>
                </div>
                <div class="col-6">
                    <label class="form-label small fw-bold text-secondary text-uppercase">Số CCCD (*)</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-id-card"></i></span>
                        <input type="text" name="cccd" class="form-control rounded-end-3" placeholder="12 số căn cước" required />
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-secondary text-uppercase">Địa chỉ Email (*)</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa-solid fa-envelope"></i></span>
                    <input type="email" name="email" class="form-control rounded-end-3" placeholder="VD: khachhang@gmail.com" required />
                </div>
                <small class="text-muted d-block mt-1">Chúng tôi sẽ gửi mã OTP xác minh đăng ký tới Email này.</small>
            </div>

            <button type="submit" class="btn btn-register w-100 py-3 text-uppercase">Gửi OTP xác thực</button>
        </form>

        <div class="text-center mt-4 text-muted small">
            Đã có tài khoản? <a asp-controller="Account" asp-action="Login" class="fw-bold text-decoration-none text-primary">Đăng nhập ngay</a>
        </div>
    </div>
</body>
</html>
