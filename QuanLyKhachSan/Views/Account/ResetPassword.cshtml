@{
    ViewData["Title"] = "Đặt Lại Mật Khẩu";
    Layout = null;
    var token = ViewBag.Token as string ?? "";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đặt lại mật khẩu — K-Hotel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #0C0C0E 0%, #1a2a3a 50%, #1e3a5f 100%);
            display: flex; align-items: center; justify-content: center;
            min-height: 100vh; font-family: system-ui, sans-serif;
            padding: 20px;
        }
        .reset-panel {
            background: white;
            border-radius: 24px;
            padding: 40px;
            width: 100%; max-width: 440px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }
        .logo-box {
            border: 2px solid #111; padding: 4px 12px;
            font-family: serif; font-size: 1.3rem; font-weight: bold;
            display: inline-block; letter-spacing: 1px;
            margin-bottom: 20px;
        }
        .error-box {
            background: rgba(220,53,69,0.06);
            border-left: 4px solid #dc3545;
            color: #b91c1c;
            padding: 12px;
            border-radius: 8px;
            font-size: 0.9rem;
            text-align: left;
        }
    </style>
</head>
<body>
    <div class="reset-panel text-center">
        <div class="logo-box">K-HOTEL</div>
        <h3 class="fw-bold mb-2">Đặt Lại Mật Khẩu</h3>
        <p class="text-muted small px-3 mb-4">Vui lòng nhập mật khẩu mới để thiết lập lại quyền truy cập tài khoản của bạn.</p>

        @if (ViewBag.Error != null)
        {
            <div class="error-box my-3">
                <i class="fa-solid fa-triangle-exclamation me-1"></i> @Html.Raw(ViewBag.Error)
            </div>
        }

        <form asp-controller="Account" asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="token" value="@token" />

            <div class="mb-3 text-start">
                <label class="form-label small fw-bold text-secondary text-uppercase">Mật khẩu mới (*)</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" name="password" class="form-control rounded-end-3" placeholder="Tối thiểu 6 ký tự" required autofocus />
                </div>
            </div>

            <div class="mb-4 text-start">
                <label class="form-label small fw-bold text-secondary text-uppercase">Xác nhận mật khẩu mới (*)</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent"><i class="fa-solid fa-check"></i></span>
                    <input type="password" name="confirmPassword" class="form-control rounded-end-3" placeholder="Nhập lại mật khẩu mới" required />
                </div>
            </div>
            
            <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold text-uppercase" style="background: #1e3a5f; border: none;">Đặt lại mật khẩu</button>
        </form>
    </div>
</body>
</html>
